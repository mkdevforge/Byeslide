{
  "name": "byeslide",
  "version": "0.1.2",
  "description": "Agent-first HTML presentation authoring on Reveal.js.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkdevforge/Byeslide.git"
  },
  "homepage": "https://byeslide.mkdevforge.com/",
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "byeslide": "src/cli.js"
  },
  "files": [
    "src",
    "template",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "build:template": "node src/cli.js build template",
    "check:template": "node src/cli.js check template",
    "install:browsers": "node src/cli.js install-browsers",
    "preview:template": "node src/cli.js preview template"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "reveal.js": "^6.0.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
